generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  //  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String         // Hashé avec bcrypt
  pseudo       String         @unique
  city         String
  bio          String?        @db.Text
  createdAt    DateTime       @default(now())

  // Relations
  ads          Ad[]           // Annonces créées par l'utilisateur
  messages     Message[]      // Messages envoyés
  favorites    Favorite[]     // Favoris de l'utilisateur

  // Pour les conversations, un utilisateur peut être participant 1 ou 2
  convsAsP1    Conversation[] @relation("Participant1")
  convsAsP2    Conversation[] @relation("Participant2")
}

model Ad {
  id           String         @id @default(uuid())
  type         AdType         // OFFER ou REQUEST
  title        String
  description  String         @db.Text
  category     String         // Ex: BRICOLAGE, INFORMATIQUE, MENAGE...
  city         String
  availability String         // Texte libre
  priceType    PriceType      // FREE, HOURLY, FIXED
  priceValue   Float?         // Null si FREE
  modality     Modality       // REMOTE, AT_PROVIDER, AT_CUSTOMER
  status       AdStatus       @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  favorites    Favorite[]     // Utilisateurs ayant mis cette annonce en favori
}

model Conversation {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt // Utile pour trier la boite de réception

  // Relations
  adId         String
  ad           Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)

  participant1Id String
  participant1   User      @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)

  participant2Id String
  participant2   User      @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)

  messages     Message[]
}

model Message {
  id             String       @id @default(uuid())
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  // Relations
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum AdType {
  OFFER
  REQUEST
}

enum PriceType {
  FREE
  HOURLY
  FIXED
}

enum Modality {
  REMOTE
  AT_PROVIDER
  AT_CUSTOMER
}

enum AdStatus {
  DRAFT
  PUBLISHED
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  adId      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([userId, adId]) // Empêche d'ajouter deux fois la même annonce en favori
}